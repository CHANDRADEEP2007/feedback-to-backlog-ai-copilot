# Optional. The app runs in deterministic demo mode without these values.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
SEMANTIC_DEDUP_ENABLED=false
SEMANTIC_DEDUP_THRESHOLD=0.82

# Jira Cloud example: https://your-company.atlassian.net
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_ISSUE_TYPE=Task

# Runtime settings
DATABASE_PATH=feedback_backlog.db
DATASET_PATH=data/aa_dataset-tickets-multi-lang-5-2-50-version.csv
DEDUP_THRESHOLD=85
GOLD_SET_PATH=eval/gold_set.csv
